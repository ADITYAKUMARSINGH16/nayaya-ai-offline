# =============================================================================
# Nyaya AI — environment variable template.
# Copy this to `.env` and fill in real values. Do NOT commit `.env`.
# =============================================================================

# -- App --
APP_ENV=development                                           # development | production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173      # comma-separated origins your frontend serves from

# -- Auth (Supabase JWT) --
# In production set AUTH_REQUIRED=true so unverifiable tokens get a 401 instead
# of silently dropping to anonymous mode.
AUTH_REQUIRED=false
SUPABASE_JWT_SECRET=                                          # the HS256 secret from Supabase project settings (required if AUTH_REQUIRED=true)
SUPABASE_JWT_AUDIENCE=authenticated                           # default Supabase audience
ADMIN_EMAILS=                                                 # comma-separated allowlist, e.g. you@example.com,alice@example.com
ADMIN_INTERNAL_KEY=                                           # long random string shared with n8n for callback authentication

# -- LLM provider --
LLM_PROVIDER=groq                                             # groq | openai | ollama
GROQ_API_KEY=                                                 # from https://console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile                            # main reasoning model
GROQ_FAST_MODEL=llama-3.1-8b-instant                          # used for classifier / verifier / HyDE
OPENAI_API_KEY=                                               # only if LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5-nano
OPENAI_FAST_MODEL=gpt-5-nano
OLLAMA_BASE_URL=http://host.docker.internal:11434             # local Ollama daemon
OLLAMA_MODEL=llama3.1

# -- Embeddings --
EMBEDDINGS_PROVIDER=ollama                                    # ollama | openai
EMBEDDINGS_MODEL=nomic-embed-text                             # must match what the vectors were seeded with
EMBEDDINGS_DIM=768                                            # nomic-embed-text = 768, text-embedding-3-small = 1536

# -- Vector store --
VECTOR_STORE_PROVIDER=qdrant                                  # qdrant | pinecone
# Qdrant
QDRANT_URL=http://qdrant:6333                                 # docker-compose service name
QDRANT_API_KEY=                                               # only if you put auth in front
QDRANT_COLLECTION=rag-legal                                   # main statute corpus
QDRANT_CASE_LAWS_COLLECTION=case-laws                         # Supreme Court precedents (seeded by seed_qdrant_full.py)
# Pinecone (alternative)
PINECONE_API_KEY=
PINECONE_INDEX=rag-legal
PINECONE_CASE_LAWS_INDEX=case-laws
PINECONE_HOST=                                                # only set for Pinecone Local

# -- Supabase --
SUPABASE_URL=                                                 # e.g. https://abcd1234.supabase.co  OR  http://127.0.0.1:54321 (local CLI)
SUPABASE_ANON_KEY=                                            # safe for browser
SUPABASE_SERVICE_KEY=                                         # backend-only, NEVER expose to the browser

# -- n8n --
N8N_WEBHOOK_BASE=http://n8n:5678/webhook                      # docker-compose service:port path
N8N_FIR_APPROVAL=false                                        # set true to route FIRs through the human-approval workflow
N8N_NOTIFY_ON_VERDICT=true                                    # set true to trigger case-notify-fanout after every trial

# -- PDF proxy cache --
PDF_CACHE_DIR=/tmp/nyaya_pdf_cache                            # where extracted Supreme Court PDFs are cached
PDF_CACHE_MAX_BYTES=524288000                                 # LRU eviction cap (default 500 MB)
