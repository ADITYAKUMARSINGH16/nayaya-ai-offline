n8n_data/

# Auto-generated data (regenerated by scripts/build_graph.py + scripts/enrich_sections.py)
data/legal_graph.json
data/sections_llm*.json
# NOTE: sections_enriched.json is REQUIRED at runtime — section_lookup.py
# (Tier 1/2 of the RAG router) loads it on every deploy. Keep it committed.

# Source PDFs — downloadable from PRS India, see README for links
data/*.pdf

# Backups left by `sed -i.bak`
*.bak

# Local databases / coverage
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
.coverage
htmlcov/
coverage/
.tox/

# Exception: LightRAG knowledge graph IS shipped with the repo — it's the
# output of a one-time ingest (~$1 OpenAI) that production needs at runtime.
!data/lightrag/knowledge_graph.db
